# GovBB Application Tracker — environment variables.
# Copy to .env and fill in for local dev, or set on Render for production.
#
# Required in production (NODE_ENV=production):

# PostgreSQL connection string. For local dev, create a database and point here.
# On Render, the managed Postgres addon sets this automatically.
DATABASE_URL=postgresql://localhost:5432/govbb_tracker

# Set to 'false' to disable SSL for the Postgres connection (local dev).
# Production connections (non-localhost) use SSL by default.
# DATABASE_SSL=false

# Long random string. Used to sign session cookies. Rotating this signs
# everyone out. Generate with: openssl rand -base64 48
SESSION_SECRET=

# The public URL of this deployment. Used in confirmation emails so the
# "Track your application" link points at the right place.
TRACKER_BASE_URL=https://your-service.onrender.com

# Resend API key. Get one at https://resend.com. Free tier is enough for the
# pilot. Without this, emails are still written to /var/data/mail-out/ for
# audit but no real email is sent.
RESEND_API_KEY=

# The "From" address. Use Resend's onboarding@resend.dev to start, or a
# verified address on a domain you control once DNS is set.
FROM_EMAIL=GovBB Tracker <onboarding@resend.dev>

# API key the alpha.gov.bb forms processor will use to push submissions in.
# If unset, seed.js will generate one and print it once on first deploy.
INCOMING_API_KEY=

# Bootstrap passwords for the seeded officers. These exist only so the seeded
# admin (Andrea) can sign in on first deploy. After that, all password
# management happens via the email-link reset flow — admins never enter
# passwords for other officers. Login is by email address, not username.
# If unset, seed.js generates random bootstrap passwords and prints them once.
OFFICER_PASSWORD_ANDREA=
OFFICER_PASSWORD_TREVOR=
OFFICER_PASSWORD_JOY=

# How long password-setup links stay valid. Default 24.
PASSWORD_TOKEN_TTL_HOURS=24

# Optional: paths for file storage. On Render, the persistent disk mount
# overrides these. The database is now Postgres (no local file needed).
TRACKER_DATA_DIR=/var/data
MAIL_OUT_DIR=/var/data/mail-out
# Where citizen-uploaded files (responses to "action needed" requests) are
# stored on disk. Files are served via an officer-only authenticated endpoint;
# they are NEVER exposed by a static route.
UPLOAD_DIR=/var/data/uploads

# Set automatically by the platform; included for clarity.
NODE_ENV=production
PORT=3030
